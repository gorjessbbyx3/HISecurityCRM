author = 47772069
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install --production"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build"

[[workflows.workflow]]
name = "Production Start"
author = 47772069
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm start"

[[workflows.workflow]]
name = "Development"
author = 47772069
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[agent]
integrations = ["javascript_supabase:1.0.0", "javascript_mem_db:1.0.0", "javascript_log_in_with_replit:1.0.0"]
expertMode = true
